<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aiBrief.loginUpdate</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/baoying/Desktop/AI简报/offline-solution.py</string>
